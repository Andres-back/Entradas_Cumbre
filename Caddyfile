# Caddy reverse proxy para Cumbre Impacto Putumayo 2026
# Define DOMAIN en .env.production con el dominio real del nuevo evento.

{$DOMAIN} {
  encode zstd gzip
  reverse_proxy app:3000

  header {
    X-Content-Type-Options "nosniff"
    X-Frame-Options "SAMEORIGIN"
    Referrer-Policy "strict-origin-when-cross-origin"
  }
}
