# ============================================================
# Bajo el Capo - Produccion
# Copiar este archivo como .env.production y llenar los valores
# ============================================================

# ---- Base de datos ----
# host=db porque el contenedor de postgres se llama "db" en docker-compose
DATABASE_URL="postgresql://bajoelcapo:REEMPLAZAR_PASSWORD_SEGURO@db:5432/bajoelcapo?schema=public"

# Password de postgres (debe coincidir con docker-compose.yml)
DB_PASSWORD="REEMPLAZAR_PASSWORD_SEGURO"
DB_HOST="db"
DB_PORT="5432"
DB_USER="bajoelcapo"

# ---- Auth.js ----
# Generar con: openssl rand -base64 32
AUTH_SECRET="REEMPLAZAR_CON_OUTPUT_DE_openssl_rand_base64_32"

# URL publica de la app (https://tudominio.com)
AUTH_URL="https://REEMPLAZAR_DOMINIO"

# ---- Admin seed (solo primer deploy) ----
ADMIN_NAME="Fredy"
ADMIN_EMAIL="fredy@gmail.com"
ADMIN_TELEFONO="+573118268444"
ADMIN_INITIAL_PASSWORD="REEMPLAZAR_PASSWORD_SEGURO_ADMIN"

# ---- Evento ----
EVENT_PRICE_COP=25000
EVENT_DATE="2026-06-20T18:00:00-05:00"
EVENT_AFORO=150

# ---- WhatsApp ----
WHATSAPP_ADMIN_NUMBER="573118268444"

# ---- Dominio para Caddy ----
DOMAIN="REEMPLAZAR_DOMINIO"
